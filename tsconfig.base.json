{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@school-policy/shared": ["packages/shared/src/index.ts"],
      "@school-policy/db": ["packages/db/src/index.ts"],
      "@school-policy/policy-registry": ["packages/policy-registry/src/index.ts"],
      "@school-policy/crawler": ["packages/crawler/src/index.ts"],
      "@school-policy/pdf": ["packages/pdf/src/index.ts"],
      "@school-policy/matching": ["packages/matching/src/index.ts"],
      "@school-policy/rules": ["packages/rules/src/index.ts"]
    }
  }
}
