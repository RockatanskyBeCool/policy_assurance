# Local Supabase Postgres direct connection.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# For deployed Supabase, set DATABASE_URL to the project's direct or pooled Postgres connection string.
# Example shape only:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-or-project-service-role-key
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_ROOT=./storage
DEPARTMENT_API_BASE_URL=https://department.example/api
DEPARTMENT_API_TOKEN=replace-me
API_PORT=3001
VITE_API_BASE_URL=http://localhost:3001

# Qwen / Alibaba Cloud Model Studio extraction.
ALIBABA_API_KEY=replace-me
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen3-vl-32b-instruct
DATA_DIR=./data
MAX_CANDIDATE_PAGES=10
RASTER_DPI=180
MIN_OVERALL_CONFIDENCE=0.75
MIN_CRITICAL_FIELD_CONFIDENCE=0.65
MAX_EXTRACTION_ATTEMPTS=4
